              "memberId": "ba43fe3c-deb2-4938-91f6-cf3d4df2530a",
              "memberColor": "#5a7eb0"
            }
          ]
        }
      ]
    },
    {
      "id": "1772537390223",
      "question": "How might we simplify the interface so coaches don’t waste time navigating menus?",
      "answers": [
        {
          "id": "1772537564213",
          "text": "A menu with 4 large buttons: Tactics, Players, Opponent, Alerts.",
          "votes": []
        },
        {
          "id": "1772537580364",
          "text": "Quick gestures (swipe left/right) to switch between screens.",
