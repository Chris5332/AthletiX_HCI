{
  "insights": [
    {
      "id": "1772537007368",
      "text": "Coaches don't have time to navigate through complex menus during the match.\nCoaches want to quickly see the physical condition of players (stamina, injury risk).\nTechnical staff needs short and clear instructions",
      "clusterId": "1772537128344"
    },
    {
      "id": "1772537224712",
      "text": "During the break in the match, coaches have time for more detailed analysis",
      "clusterId": "1772537258134"
    }
  ],
  "clusters": [
    {
      "id": "1772537128344",
      "name": "Real-Time Decision Making",
      "statement": "Coaches need instant access to the most critical match and player information, in a simple format, so they can make fast decisions without losing focus on the game.",
      "color": "#103162",
      "insightIds": []
    },
    {
      "id": "1772537258134",
      "name": "Communication & Coordination",
      "statement": "Coaches and staff need different levels of information depending on the match moment: quick, concise communication during play and more detailed analysis during breaks.",
      "color": "#7D9BC8",
      "insightIds": []
    }
  ],
  "hmws": [
    {
      "id": "1772537336898",
      "question": "How might we help coaches access critical information instantly during the match?",
      "answers": [
        {
          "id": "1772537427655",
          "text": "A dashboard with 3 major indicators: stamina, injury risk, performance.",
          "votes": [
            {
              "memberId": "4cddd3a6-da87-4338-bfc9-419462cce4bc",
              "memberColor": "#103162"
            },
            {
              "memberId": "016d782c-9679-46fa-951f-b4764b17cc56",
              "memberColor": "#7D9BC8"
            },
            {
              "memberId": "6f6e8a4d-8d15-4e21-b00a-63b463e75014",
              "memberColor": "#FF8E70"
            }
          ]
        },
        {
          "id": "1772537465880",
          "text": "Smart alerts that appear automatically when a player drops below a certain threshold",
          "votes": [
            {
              "memberId": "016d782c-9679-46fa-951f-b4764b17cc56",
              "memberColor": "#7D9BC8"
            },
            {
